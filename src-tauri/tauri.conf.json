{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura Launcher",
  "version": "0.1.0",
  "identifier": "studio.aura.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aura Launcher",
        "width": 1180,
        "height": 720,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
